+    IR2_OPND mxcsr = ra_alloc_itemp();
+    bool is_xmm = ir1_opnd_is_xmm(opnd0);
+    if(imm & 0x8){
+        IR2_INST * ( * tr_inst)(IR2_OPND, IR2_OPND, IR2_OPND, int);
