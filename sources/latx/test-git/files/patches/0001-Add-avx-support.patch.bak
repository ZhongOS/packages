+
+    if (ir1_opnd_is_xmm(opnd0)) {
+        la_xvreplve0_w(dest, src);
+    } else if (ir1_opnd_is_ymm(opnd0)) {
+        la_xvreplve0_w(dest, src);
+        la_xvinsve0_d(dest, dest, 2);
+        la_xvinsve0_d(dest, dest, 3);
+    } else {
+        lsassert(0);
