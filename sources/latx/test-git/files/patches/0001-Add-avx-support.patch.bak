+    tr_inst(fcc0_ir2_opnd, src1, src2, 0x3);
+    la_fsel(temp, src2, src1, fcc0_ir2_opnd);
+    if (ir1_opnd_base_reg_num(opnd0) != ir1_opnd_base_reg_num(opnd1)) {
+        la_xvori_b(dest, src1, 0);
