From e897af10cbf689f003761f926027bc5a32e1a259 Mon Sep 17 00:00:00 2001
From: zhaodongru <zhaodongru@loongson-pc>
Date: Fri, 18 Apr 2025 20:37:16 +0800
Subject: [PATCH 1/3] Add avx support

---
 configure                                   |    8 +-
 target/i386/cpu.c                           |   50 +-
 target/i386/latx/include/optimize-config.h  |    2 +
 target/i386/latx/include/translate.h        |  403 ++
 target/i386/latx/ir1/ir1.c                  |    6 +
 target/i386/latx/translator/meson.build     |    2 +
 target/i386/latx/translator/tr-simd-cmp.c   | 3340 +++++++++-
 target/i386/latx/translator/tr-simd-cvt.c   |  844 ++-
 target/i386/latx/translator/tr-simd-f16c.c  |   77 +
 target/i386/latx/translator/tr-simd-fma.c   |  182 +
 target/i386/latx/translator/tr-simd-mov.c   |  577 ++
 target/i386/latx/translator/tr-simd-shift.c |  242 +
 target/i386/latx/translator/tr-simd.c       | 6208 ++++++++++++++++++-
 target/i386/latx/translator/tr-softfpu.c    |   79 +-
 target/i386/latx/translator/translate.c     |  556 +-
 target/i386/ops_sse.h                       |   89 +
 target/i386/ops_sse_header.h                |    9 +
 17 files changed, 12449 insertions(+), 225 deletions(-)
 create mode 100644 target/i386/latx/translator/tr-simd-f16c.c
 create mode 100644 target/i386/latx/translator/tr-simd-fma.c

diff --git a/configure b/configure
index d3e30c8..9ca90e9 100755
--- a/configure
+++ b/configure
@@ -239,7 +239,7 @@ fi
 #   meson will not detect the ccache.
 # So we need to add 'ccache' here, instead of use meson to detect.
 # Also, meson will do double check, if 'ccache' not exsits, meson
-#   will delete 'ccache' and remain 'cc'. 
+#   will delete 'ccache' and remain 'cc'.
 ccache=""
 if [ -x "$(command -v ccache)" ]; then
   ccache="ccache"
@@ -406,6 +406,7 @@ guest_base_zero="no"
 latx_capstone_git="yes"
 latx_atomic="no"
 latx_xcomisx_opt="no"
+latx_avx_opt="no"
 capstone_diet="yes"
 latx_syscall_tunnel="no"
 latx_tbmini_enable="yes"
@@ -1203,6 +1204,8 @@ for opt do
   ;;
   --enable-latx-xcomisx-opt) latx_xcomisx_opt="yes"
   ;;
+  --enable-latx-avx-opt) latx_avx_opt="yes"
+  ;;
   --disable-capstone-diet) capstone_diet="no"
   ;;
   --enable-latx-syscall-tunnel) latx_syscall_tunnel="yes"
@@ -5716,6 +5719,9 @@ if test "$latx" = "yes" ; then
   if test "$latx_xcomisx_opt" = "yes" ; then
   echo "CONFIG_LATX_XCOMISX_OPT=y" >> $config_host_mak
   fi
+  if test "$latx_avx_opt" = "yes" ; then
+  echo "CONFIG_LATX_AVX_OPT=y" >> $config_host_mak
+  fi
   if test "$capstone_diet" = "yes" ; then
     echo "CONFIG_CAPSTONE_DIET=y" >> $config_host_mak
   fi
diff --git a/target/i386/cpu.c b/target/i386/cpu.c
index 29c7d57..975aea2 100644
--- a/target/i386/cpu.c
+++ b/target/i386/cpu.c
@@ -626,12 +626,21 @@ static void x86_cpu_vendor_words2str(char *dst, uint32_t vendor1,
           /* missing:
           CPUID_VME, CPUID_DTS, CPUID_SS, CPUID_HT, CPUID_TM, CPUID_PBE */
 
+#ifdef CONFIG_LATX_AVX_OPT
+#define TCG_EXT_FEATURES (CPUID_EXT_SSE3 | CPUID_EXT_PCLMULQDQ | \
+          CPUID_EXT_MONITOR | CPUID_EXT_SSSE3 | CPUID_EXT_CX16 | \
+          CPUID_EXT_SSE41 | CPUID_EXT_SSE42 | CPUID_EXT_POPCNT | \
+          CPUID_EXT_XSAVE | /* CPUID_EXT_OSXSAVE is dynamic */   \
+          CPUID_EXT_MOVBE | CPUID_EXT_AES | CPUID_EXT_HYPERVISOR | \
+          CPUID_EXT_RDRAND | CPUID_EXT_AVX | CPUID_EXT_FMA | CPUID_EXT_F16C )
+#else
 #define TCG_EXT_FEATURES (CPUID_EXT_SSE3 | CPUID_EXT_PCLMULQDQ | \
           CPUID_EXT_MONITOR | CPUID_EXT_SSSE3 | CPUID_EXT_CX16 | \
           CPUID_EXT_SSE41 | CPUID_EXT_SSE42 | CPUID_EXT_POPCNT | \
           CPUID_EXT_XSAVE | /* CPUID_EXT_OSXSAVE is dynamic */   \
           CPUID_EXT_MOVBE | CPUID_EXT_AES | CPUID_EXT_HYPERVISOR | \
           CPUID_EXT_RDRAND)
+#endif
           /* missing:
           CPUID_EXT_DTES64, CPUID_EXT_DSCPL, CPUID_EXT_VMX, CPUID_EXT_SMX,
           CPUID_EXT_EST, CPUID_EXT_TM2, CPUID_EXT_CID, CPUID_EXT_FMA,
@@ -654,21 +663,32 @@ static void x86_cpu_vendor_words2str(char *dst, uint32_t vendor1,
 #define TCG_EXT4_FEATURES 0
 #define TCG_SVM_FEATURES CPUID_SVM_NPT
 #define TCG_KVM_FEATURES 0
-
+#ifdef CONFIG_LATX_AVX_OPT
+#define TCG_7_0_EBX_FEATURES (CPUID_7_0_EBX_SMEP | CPUID_7_0_EBX_SMAP | \
+          CPUID_7_0_EBX_BMI1 | CPUID_7_0_EBX_BMI2 | CPUID_7_0_EBX_ADX | \
+          CPUID_7_0_EBX_PCOMMIT | CPUID_7_0_EBX_CLFLUSHOPT |            \
+          CPUID_7_0_EBX_CLWB | CPUID_7_0_EBX_MPX | CPUID_7_0_EBX_FSGSBASE | \
+          CPUID_7_0_EBX_ERMS | CPUID_7_0_EBX_AVX2 | CPUID_7_0_EBX_HLE)
+#else
 #define TCG_7_0_EBX_FEATURES (CPUID_7_0_EBX_SMEP | CPUID_7_0_EBX_SMAP | \
           CPUID_7_0_EBX_BMI1 | CPUID_7_0_EBX_BMI2 | CPUID_7_0_EBX_ADX | \
           CPUID_7_0_EBX_PCOMMIT | CPUID_7_0_EBX_CLFLUSHOPT |            \
           CPUID_7_0_EBX_CLWB | CPUID_7_0_EBX_MPX | CPUID_7_0_EBX_FSGSBASE | \
           CPUID_7_0_EBX_ERMS)
+#endif
           /* missing:
           CPUID_7_0_EBX_HLE, CPUID_7_0_EBX_AVX2,
           CPUID_7_0_EBX_INVPCID, CPUID_7_0_EBX_RTM,
           CPUID_7_0_EBX_RDSEED */
-
+#ifdef CONFIG_LATX_AVX_OPT
+#define TCG_7_0_ECX_FEATURES (CPUID_7_0_ECX_PKU | \
+          /* CPUID_7_0_ECX_OSPKE is dynamic */ \
+          CPUID_7_0_ECX_LA57)
+#else
 #define TCG_7_0_ECX_FEATURES (CPUID_7_0_ECX_PKU | \
           /* CPUID_7_0_ECX_OSPKE is dynamic */ \
           CPUID_7_0_ECX_LA57 | CPUID_7_0_ECX_PKS)
-
+#endif
 #define TCG_7_0_EDX_FEATURES 0
 #define TCG_7_1_EAX_FEATURES 0
 #define TCG_APM_FEATURES 0
@@ -1890,6 +1910,9 @@ static X86CPUDefinition builtin_x86_defs[] = {
             CPUID_MTRR | CPUID_CLFLUSH | CPUID_MCA |
             CPUID_PSE36,
         .features[FEAT_1_ECX] =
+#ifdef CONFIG_LATX_AVX_OPT
+            CPUID_EXT_AVX | CPUID_EXT_FMA | CPUID_EXT_XSAVE |
+#endif
 #ifdef CONFIG_LATX_SSSE3_SSE4
             CPUID_EXT_AES | CPUID_EXT_POPCNT | CPUID_EXT_SSE42 |
             CPUID_EXT_SSE41 | CPUID_EXT_CX16 | CPUID_EXT_SSSE3 |
@@ -1900,6 +1923,15 @@ static X86CPUDefinition builtin_x86_defs[] = {
             CPUID_EXT2_LM | CPUID_EXT2_SYSCALL | CPUID_EXT2_NX,
         .features[FEAT_8000_0001_ECX] =
             CPUID_EXT3_LAHF_LM | CPUID_EXT3_SVM,
+#ifdef CONFIG_LATX_AVX_OPT
+        .features[FEAT_7_0_EBX] =
+        CPUID_7_0_EBX_HLE |
+            CPUID_7_0_EBX_BMI1 |
+            CPUID_7_0_EBX_AVX2 |
+            CPUID_7_0_EBX_BMI2,
+        .features[FEAT_XSAVE] =
+            CPUID_XSAVE_XSAVEOPT | CPUID_XSAVE_XGETBV1,
+#endif
         .xlevel = 0x8000000A,
         .model_id = "LATX64 Virtual CPU @ 2.5GHz",
     },
@@ -2028,6 +2060,9 @@ static X86CPUDefinition builtin_x86_defs[] = {
         .features[FEAT_1_EDX] =
             PPRO_FEATURES,
         .features[FEAT_1_ECX] =
+#ifdef CONFIG_LATX_AVX_OPT
+            CPUID_EXT_AVX | CPUID_EXT_FMA | CPUID_EXT_XSAVE |
+#endif
 #ifdef CONFIG_LATX_SSSE3_SSE4
             CPUID_EXT_AES | CPUID_EXT_POPCNT | CPUID_EXT_SSE42 |
             CPUID_EXT_SSE41 | CPUID_EXT_CX16 | CPUID_EXT_SSSE3 |
@@ -2036,6 +2071,15 @@ static X86CPUDefinition builtin_x86_defs[] = {
             CPUID_EXT_SSE3,
         .features[FEAT_8000_0001_ECX] =
             CPUID_EXT3_LAHF_LM | CPUID_EXT3_SVM,
+#ifdef CONFIG_LATX_AVX_OPT
+        .features[FEAT_7_0_EBX] =
+        CPUID_7_0_EBX_HLE |
+            CPUID_7_0_EBX_BMI1 |
+            CPUID_7_0_EBX_AVX2 |
+            CPUID_7_0_EBX_BMI2,
+        .features[FEAT_XSAVE] =
+            CPUID_XSAVE_XSAVEOPT | CPUID_XSAVE_XGETBV1,
+#endif
         .xlevel = 0x80000004,
         .model_id = "LATX32 Virtual CPU @ 2.5GHz",
     },
diff --git a/target/i386/latx/include/optimize-config.h b/target/i386/latx/include/optimize-config.h
index 07f73f5..f40c391 100644
--- a/target/i386/latx/include/optimize-config.h
+++ b/target/i386/latx/include/optimize-config.h
@@ -106,6 +106,8 @@
 #ifdef _OPT_TESTING_
 #undef CONFIG_LATX_SYSCALL_TUNNEL
 #define CONFIG_LATX_SYSCALL_TUNNEL
+#undef CONFIG_LATX_AVX_OPT
+#define CONFIG_LATX_AVX_OPT
 #endif
 
 /**
