+bool translate_vcmpneqpd(IR1_INST * pir1) {
+    lsassert((ir1_opnd_is_xmm(ir1_get_opnd(pir1, 0)) &&
+            ir1_opnd_is_xmm(ir1_get_opnd(pir1, 1))) ||
