+DEF_HELPER_4(glue(vaesenc, SUFFIX), void, env, Reg, Reg, Reg)
+DEF_HELPER_4(glue(vaesenclast, SUFFIX), void, env, Reg, Reg, Reg)
+DEF_HELPER_5(glue(vpclmulqdq, SUFFIX), void, env, Reg, Reg, Reg, i32)
+#endif
+#endif
 
 #undef SHIFT
 #undef Reg
