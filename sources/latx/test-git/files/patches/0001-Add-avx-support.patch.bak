+    la_bstrpick_w(fcsr_save, fcsr, 31, 0);
+    la_ld_wu(mxcsr, env_ir2_opnd,
+            lsenv_offset_of_mxcsr(lsenv));
+    la_bstrins_w(fcsr, zero_ir2_opnd, 4, 0);
