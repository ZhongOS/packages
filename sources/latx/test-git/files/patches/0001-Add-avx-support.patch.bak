+        la_xvsrli_d(temp, temp, 0x3f);
+        la_xvseteqz_v(fcc0_ir2_opnd, temp); //temp==0 fcc=1;
+        la_bceqz(fcc0_ir2_opnd, label_2); //fcc==1,not jump
