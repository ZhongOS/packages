From 76262ecb6b247a4fd219c613a30170257cb83ba7 Mon Sep 17 00:00:00 2001
From: Sun Haiyong <sunhaiyong@zdbr.net>
Date: Sat, 6 Jan 2024 07:10:20 +0000
Subject: [PATCH] Fix compiler error when using gcc-14.

fixed error message:
	error: 'calloc' sizes specified with 'sizeof' in the earlier argument and not in the later argument [-Werror=calloc-transposed-args]
---
 tools/perf/builtin-record.c        | 2 +-
 tools/perf/util/hist.c             | 2 +-
 tools/perf/util/metricgroup.c      | 2 +-
 tools/perf/util/synthetic-events.c | 4 ++--
 4 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/tools/perf/builtin-record.c b/tools/perf/builtin-record.c
index dcf288a4f..9f75519cc 100644
--- a/tools/perf/builtin-record.c
+++ b/tools/perf/builtin-record.c
@@ -4083,7 +4083,7 @@ int cmd_record(int argc, const char **argv)
 	}
 
 	if (rec->switch_output.num_files) {
-		rec->switch_output.filenames = calloc(sizeof(char *),
+		rec->switch_output.filenames = calloc((int)sizeof(char *),
 						      rec->switch_output.num_files);
 		if (!rec->switch_output.filenames) {
 			err = -EINVAL;
diff --git a/tools/perf/util/hist.c b/tools/perf/util/hist.c
index 0888b7163..64de68f34 100644
--- a/tools/perf/util/hist.c
+++ b/tools/perf/util/hist.c
@@ -491,7 +491,7 @@ static int hist_entry__init(struct hist_entry *he,
 	}
 
 	if (symbol_conf.res_sample) {
-		he->res_samples = calloc(sizeof(struct res_sample),
+		he->res_samples = calloc((int)sizeof(struct res_sample),
 					symbol_conf.res_sample);
 		if (!he->res_samples)
 			goto err_srcline;
diff --git a/tools/perf/util/metricgroup.c b/tools/perf/util/metricgroup.c
index ca3e0404f..fbe68f9bc 100644
--- a/tools/perf/util/metricgroup.c
+++ b/tools/perf/util/metricgroup.c
@@ -286,7 +286,7 @@ static int setup_metric_events(const char *pmu, struct hashmap *ids,
 	*out_metric_events = NULL;
 	ids_size = hashmap__size(ids);
 
-	metric_events = calloc(sizeof(void *), ids_size + 1);
+	metric_events = calloc((int)sizeof(void *), ids_size + 1);
 	if (!metric_events)
 		return -ENOMEM;
 
diff --git a/tools/perf/util/synthetic-events.c b/tools/perf/util/synthetic-events.c
index a0579c7d7..2907bded4 100644
--- a/tools/perf/util/synthetic-events.c
+++ b/tools/perf/util/synthetic-events.c
@@ -1039,11 +1039,11 @@ int perf_event__synthesize_threads(struct perf_tool *tool,
 	if (thread_nr > n)
 		thread_nr = n;
 
-	synthesize_threads = calloc(sizeof(pthread_t), thread_nr);
+	synthesize_threads = calloc((int)sizeof(pthread_t), thread_nr);
 	if (synthesize_threads == NULL)
 		goto free_dirent;
 
-	args = calloc(sizeof(*args), thread_nr);
+	args = calloc((int)sizeof(*args), thread_nr);
 	if (args == NULL)
 		goto free_threads;
 
-- 
2.31.1

