From 11486e3b688126f6045e4f478b0d79baaea6c357 Mon Sep 17 00:00:00 2001
From: Sun Haiyong <sunhaiyong@zdbr.net>
Date: Sat, 2 May 2026 15:44:50 +0000
Subject: [PATCH] jq remove oniguruma LDFLAGS rpath flag.

---
 configure    | 2 +-
 configure.ac | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/configure b/configure
index 3f8d0ec..fe687e7 100755
--- a/configure
+++ b/configure
@@ -23490,7 +23490,7 @@ fi
 then :
 
        onig_CFLAGS="-I${srcdir}/vendor/oniguruma/src"
-       onig_LDFLAGS="-L${srcdir}/vendor/oniguruma/src -Wl,-rpath,${libdir}"
+       onig_LDFLAGS="-L${srcdir}/vendor/oniguruma/src"
        subdirs="$subdirs vendor/oniguruma"
 
 
diff --git a/configure.ac b/configure.ac
index f7067a4..5960bfc 100644
--- a/configure.ac
+++ b/configure.ac
@@ -278,7 +278,7 @@ AS_IF([test "x$with_oniguruma" != xno], [
    ])
    AS_IF([test "x$build_oniguruma" = xyes && test -f "${srcdir}/vendor/oniguruma/configure.ac" ], [
        onig_CFLAGS="-I${srcdir}/vendor/oniguruma/src"
-       onig_LDFLAGS="-L${srcdir}/vendor/oniguruma/src -Wl,-rpath,${libdir}"
+       onig_LDFLAGS="-L${srcdir}/vendor/oniguruma/src"
        AC_CONFIG_SUBDIRS([vendor/oniguruma])
        AC_DEFINE([HAVE_LIBONIG],1,[Define to 1 if the system includes libonig])
    ])
-- 
2.31.1

