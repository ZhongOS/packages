From 4963affa43660ad002679f781cd8202f370c5142 Mon Sep 17 00:00:00 2001
From: Sun Haiyong <sunhaiyong@zdbr.net>
Date: Wed, 6 May 2026 07:43:17 +0000
Subject: [PATCH 7/9] UniVT: Support displaying UTF-8 text for 90 degree
 rotation.
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

支持显示内容进行90度旋转时显示UTF-8文字。
---
 drivers/video/fbdev/core/fbcon_cw.c | 39 +++++++++++++++++++++++++++--
 1 file changed, 33 insertions(+), 2 deletions(-)

diff --git a/drivers/video/fbdev/core/fbcon_cw.c b/drivers/video/fbdev/core/fbcon_cw.c
index bde820967..c75003366 100644
--- a/drivers/video/fbdev/core/fbcon_cw.c
+++ b/drivers/video/fbdev/core/fbcon_cw.c
@@ -19,6 +19,8 @@
 #include "fbcon.h"
 #include "fbcon_rotate.h"
 
+extern u16 utf8_pos(struct vc_data *vc, const unsigned short *utf8);
+
 /*
  * Rotation 90 degrees
  */
@@ -90,13 +92,28 @@ static inline void cw_putcs_aligned(struct vc_data *vc, struct fb_info *info,
 	u32 idx = font_glyph_pitch(vc->vc_font.height);
 	u8 *src;
 
+	int utf8_c = 0;
 	while (cnt--) {
-		src = par->rotated.buf + (scr_readw(s++) & charmask) * cellsize;
+		utf8_c = utf8_pos(vc, s);
+		if(((scr_readw(s) & charmask) == 0xff || (scr_readw(s) & charmask) == 0xfe ) &&  utf8_c != 0){
+			char dst[16];
+			utf8_c -= 128;
+			if((scr_readw(s) & charmask) == 0xff){
+				src = vc->vc_font.data + (utf8_c * 32);
+			}else{
+				src = vc->vc_font.data + (utf8_c * 32 + 16);
+			}
+			font_glyph_rotate_90(src, vc->vc_font.width, vc->vc_font.height, dst);
+			src = dst;
+		}else{
+			src = par->rotated.buf + (scr_readw(s) & charmask) * cellsize;
+		}
 
 		if (attr) {
 			cw_update_attr(buf, src, attr, vc);
 			src = buf;
 		}
+		s++;
 
 		if (likely(idx == 1))
 			__fb_pad_aligned_buffer(dst, d_pitch, src, idx,
@@ -209,6 +228,7 @@ static void cw_cursor(struct vc_data *vc, struct fb_info *info, bool enable,
 	unsigned short charmask = vc->vc_hi_font_mask ? 0x1ff : 0xff;
 	int w = font_glyph_pitch(vc->vc_font.height);
 	int c;
+	int c_extra;
 	int y = real_y(par->p, vc->state.y);
 	int attribute, use_sw = vc->vc_cursor_type & CUR_SW;
 	int err = 1, dx, dy;
@@ -221,8 +241,21 @@ static void cw_cursor(struct vc_data *vc, struct fb_info *info, bool enable,
 	cursor.set = 0;
 
  	c = scr_readw((u16 *) vc->vc_pos);
+ 	c_extra = utf8_pos(vc, (u16 *) vc->vc_pos);
 	attribute = get_attribute(info, c);
-	src = par->rotated.buf + ((c & charmask) * (w * vc->vc_font.width));
+	if(((c&charmask) == 0xff || (c & charmask) == 0xfe) && c_extra != 0){
+		char dst[16];
+		c_extra -= 128;
+		if((c & charmask) == 0xff){
+			src = vc->vc_font.data + (c_extra * 32);
+		}else{
+			src = vc->vc_font.data + (c_extra * 32 + 16);
+		}
+		font_glyph_rotate_90(src, vc->vc_font.width, vc->vc_font.height, dst);
+		src = dst;
+	}else{
+		src = par->rotated.buf + ((c & charmask) * (w * vc->vc_font.width));
+	}
 
 	if (par->cursor_state.image.data != src ||
 	    par->cursor_reset) {
-- 
2.31.1

