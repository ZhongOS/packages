From eee2ac733e77b64c2fe63a8d37641275af1993a1 Mon Sep 17 00:00:00 2001
From: Sun Haiyong <sunhaiyong@zdbr.net>
Date: Mon, 24 Mar 2025 07:55:03 +0000
Subject: [PATCH] chromium 134 fix std max error for swiftshader use llvm 16 .

---
 .../third_party/llvm-16.0/llvm/include/llvm/Support/AlignOf.h   | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/third_party/swiftshader/third_party/llvm-16.0/llvm/include/llvm/Support/AlignOf.h b/third_party/swiftshader/third_party/llvm-16.0/llvm/include/llvm/Support/AlignOf.h
index a8c4578..dd24301 100644
--- a/third_party/swiftshader/third_party/llvm-16.0/llvm/include/llvm/Support/AlignOf.h
+++ b/third_party/swiftshader/third_party/llvm-16.0/llvm/include/llvm/Support/AlignOf.h
@@ -20,7 +20,7 @@ namespace llvm {
 /// A suitably aligned and sized character array member which can hold elements
 /// of any type.
 template <typename T, typename... Ts> struct AlignedCharArrayUnion {
-  alignas(Ts...) char buffer[std::max({sizeof(Ts)...})];
+  alignas(Ts...) char buffer[std::max({sizeof(T), sizeof(Ts)...})];
 };
 
 } // end namespace llvm
