From 4ab5f3b481615038b46bf48f66b192bbbb9611cc Mon Sep 17 00:00:00 2001
From: Sun Haiyong <sunhaiyong@zdbr.net>
Date: Tue, 8 Aug 2023 10:26:38 +0000
Subject: [PATCH] libretro mame add loongarch64 support.

---
 3rdparty/bx/include/bx/platform.h |  8 ++++++++
 Makefile.libretro                 |  4 ++--
 makefile                          | 18 ++++++++++++++----
 3 files changed, 24 insertions(+), 6 deletions(-)

diff --git a/3rdparty/bx/include/bx/platform.h b/3rdparty/bx/include/bx/platform.h
index f14f9b68..0fbf20c8 100644
--- a/3rdparty/bx/include/bx/platform.h
+++ b/3rdparty/bx/include/bx/platform.h
@@ -26,6 +26,7 @@
 #define BX_CPU_MIPS  0
 #define BX_CPU_PPC   0
 #define BX_CPU_RISCV 0
+#define BX_CPU_LOONGARCH 0
 #define BX_CPU_X86   0
 
 // C Runtime
@@ -108,6 +109,11 @@
 #	undef  BX_CPU_RISCV
 #	define BX_CPU_RISCV 1
 #	define BX_CACHE_LINE_SIZE 64
+#elif defined(__loongarch_lp64)   \
+ ||   defined(__loongarch__)
+#	undef  BX_CPU_LOONGARCH
+#	define BX_CPU_LOONGARCH 1
+#	define BX_CACHE_LINE_SIZE 64
 #elif defined(_M_IX86)    \
  ||   defined(_M_X64)     \
  ||   defined(__i386__)   \
@@ -414,6 +420,8 @@
 #	define BX_CPU_NAME "PowerPC"
 #elif BX_CPU_RISCV
 #	define BX_CPU_NAME "RISC-V"
+#elif BX_CPU_LOONGARCH
+#	define BX_CPU_NAME "LOONGARCH"
 #elif BX_CPU_X86
 #	define BX_CPU_NAME "x86"
 #endif // BX_CPU_
diff --git a/Makefile.libretro b/Makefile.libretro
index 3dc61cb7..6a1b2c74 100644
--- a/Makefile.libretro
+++ b/Makefile.libretro
@@ -26,8 +26,8 @@ export ARCH
 #
 ###########################################################################
 
-UNAME_S = $(shell uname -s)
-UNAME_M = $(shell uname -m)
+UNAME_S = $(shell cross-uname -s)
+UNAME_M = $(shell cross-uname -m)
 
 ifeq ($(platform),)
 	platform = unix
diff --git a/makefile b/makefile
index 32292dc7..99e64971 100644
--- a/makefile
+++ b/makefile
@@ -142,9 +142,9 @@ OS := windows
 GENIEOS := windows
 PLATFORM := x86
 else
-UNAME := $(shell uname -mps)
-UNAME_M := $(shell uname -m)
-UNAME_P := $(shell uname -p)
+UNAME := $(shell cross-uname -mps)
+UNAME_M := $(shell cross-uname -m)
+UNAME_P := $(shell cross-uname -p)
 GENIEOS := linux
 PLATFORM := unknown
 ifneq ($(filter x86_64,$(UNAME_P)),)
@@ -180,6 +180,9 @@ endif
 ifneq ($(filter riscv64%,$(UNAME_M)),)
 PLATFORM := riscv64
 endif
+ifneq ($(filter loongarch64%,$(UNAME_M)),)
+PLATFORM := loongarch64
+endif
 ifneq ($(filter riscv64%,$(UNAME_P)),)
 PLATFORM := riscv64
 endif
@@ -296,7 +299,7 @@ ARCHITECTURE := _x86
 endif
 endif
 else
-UNAME    := $(shell uname -mps)
+UNAME    := $(shell cross-uname -mps)
 TARGETOS := $(OS)
 
 #-------------------------------------------------
@@ -413,6 +416,13 @@ ifndef FORCE_DRC_C_BACKEND
 endif
 endif
 
+ifeq ($(findstring loongarch64,$(UNAME)),loongarch64)
+ARCHITECTURE :=
+ifndef FORCE_DRC_C_BACKEND
+	FORCE_DRC_C_BACKEND := 1
+endif
+endif
+
 # Autodetect BIGENDIAN
 # MacOSX
 ifndef BIGENDIAN
-- 
2.31.1

