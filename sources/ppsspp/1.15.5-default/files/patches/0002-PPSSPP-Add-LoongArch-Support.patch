+LoongArch64Jit::LoongArch64Jit(MIPSState *mipsState) : blocks(mipsState, this), mips_(mipsState)
+{ 
+	logBlocks = 0;
+	dontLogBlocks = 0;
+	blocks.Init();
+	AllocCodeSpace(1024 * 1024 * 16);
+	js.startDefaultPrefix = mips_->HasDefaultPrefix();
+}
+
+void LoongArch64Jit::DoState(PointerWrap &p)
+{
+	auto s = p.Section("Jit", 1, 2);
+	if (!s)
+		return;
+
+	Do(p, js.startDefaultPrefix);
+	if (s >= 2) {
+		Do(p, js.hasSetRounding);
+		js.lastSetRounding = 0;
+	} else {
+		js.hasSetRounding = 1;
+	}
+}
