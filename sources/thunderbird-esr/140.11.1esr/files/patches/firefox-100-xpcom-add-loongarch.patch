+	    st.d	$r4, $r3, 64
+	    st.d	$r5, $r3, 72
+	    st.d	$r6, $r3, 80
+	    st.d	$r7, $r3, 88
+	    st.d	$r8, $r3, 96
+	    st.d	$r9, $r3, 104
+	    st.d	$r10,$r3, 112
+	    st.d	$r11,$r3, 120
+	    fst.d	$fa0,$r3, 0
+	    fst.d	$fa1,$r3, 8
+	    fst.d	$fa2,$r3, 16
+	    fst.d	$fa3,$r3, 24
+	    fst.d	$fa4,$r3, 32
+	    fst.d	$fa5,$r3, 40
+	    fst.d	$fa6,$r3, 48
+	    fst.d	$fa7,$r3, 56
+	  
+	    # methodindex passed form stub
+	    move	$r5, $r20
+	    
+	    addi.d	$r6, $r3, 144 #16+8*(NGPREGS+NFPREGS)
+	    addi.d	$r7, $r3, 64
+	    addi.d	$r8, $r3, 0
+
+	    la.global	$r16, PrepareAndDispatch
+	    jirl	$r1, $r16, 0
+
+	    addi.d	$r3, $r3, 128
+	    ld.d	$r1, $r3, 0
+	    ld.d	$r22,$r3, 8
+	    addi.d	$r3, $r3, 16
