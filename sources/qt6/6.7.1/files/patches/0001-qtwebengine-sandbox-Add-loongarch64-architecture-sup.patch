-  // Many systems do not yet support getrandom(2) so ENOSYS is a valid result
-  // here.
-  int ret = HANDLE_EINTR(syscall(__NR_getrandom, buf, sizeof(buf), 0));
-  BPF_ASSERT((ret == -1 && errno == ENOSYS) || ret == 1);
