From 35ddad048fdeff3a19d13a404064a3a46df3de10 Mon Sep 17 00:00:00 2001
From: Sun Haiyong <sunhaiyong@zdbr.net>
Date: Sat, 11 Apr 2026 06:13:16 +0000
Subject: [PATCH 02/10] qt 6.11.0 webengine fix loongarch64 define because
 chromium use loong64 as loongarch64.

---
 qtwebengine/cmake/QtToolchainHelpers.cmake | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/qtwebengine/cmake/QtToolchainHelpers.cmake b/qtwebengine/cmake/QtToolchainHelpers.cmake
index 2518830485..ba538a6ceb 100644
--- a/qtwebengine/cmake/QtToolchainHelpers.cmake
+++ b/qtwebengine/cmake/QtToolchainHelpers.cmake
@@ -55,6 +55,8 @@ function(get_gn_arch result arch)
         set(${result} "mips64el" PARENT_SCOPE)
     elseif(arch STREQUAL "riscv64")
         set(${result} "riscv64" PARENT_SCOPE)
+    elseif(arch STREQUAL "loongarch64")
+        set(${result} "loong64" PARENT_SCOPE)
     else()
         message(FATAL_ERROR "Unknown architecture: ${arch}")
     endif()
-- 
