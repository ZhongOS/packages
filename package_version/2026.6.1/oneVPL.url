ftp:" | "xhttp:" | "xftps:") REL_URL="${2}" ;; *) BASE_URL=${1}; HTML_SUFF=$(echo ${BASE_URL} | awk -F '/' '{ print $NF }' | awk -F '.' '{ print $NF }'); if [ "x${HTML_SUFF}" == "xhtml" ] || [ "x${HTML_SUFF}" == "xhtm" ] || [ "x${HTML_SUFF}" == "xphp" ]; then BASE_URL="${BASE_URL%/*}/"; fi; REL_URL="${BASE_URL}/${2}" ;; esac; reformat_url "${REL_URL}" } get_package_version () { declare RE_NAME=""; if [ "x${3}" != "x" ]; then RE_NAME="${3}"; else RE_NAME="${1}"; fi; RET_VAL_1=$(echo $2 | awk -F'/' '{print $NF}' | sed "s@^${RE_NAME}[-|_|\.]\{0,1\}@@g" | sed -e "s@\.tar\.[bz2|xz|gz]*\$@@g" -e "s@\.tgz\$@@g" -e "s@\.zip\$@@g" | sed -e "s@[-_\.]\{0,1\}\(source\|src\|stable\|orig\)@@g"); RET_VAL_2=$(echo "${RET_VAL_1}" | grep -v -e "[[:digit:]|-|_]latest" -e "[[:digit:]|-|_]rc[0-9]\{0,\}" -e "[[:digit:]|-|_]beta[0-9]\{0,\}" -e "[[:digit:]|-|_]alpha[0-9]\{0,\}" -e "[[:digit:]|-|_]preview[0-9]\{0,\}" ); RET_VAL=$(echo "${RET_VAL_2}" | uniq | sort -V -r | head -n 1); echo "${RET_VAL}" } get_sf_new_file () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q $(reformat_url ${2}) -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then echo "NULL"; exit; fi; declare $(bash common/sf.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_sfdir_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q $(reformat_url ${2}) -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then echo "NULL"; exit; fi; declare $(bash -e common/sfdir.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}" "${6}" "${7}"); rm ${TMP_FILE}; echo "${DIR_NAME}" } get_webpage_new_file () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q ${2} -O ${TMP_FILE}; declare $(bash common/webpage.method ${1} ${TMP_FILE}); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_webpagedir_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; declare $(bash -e common/webpagedir.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}"); rm ${TMP_FILE}; echo "${DIR_NAME}" } reformat_url () { declare URL; URL=$(echo "${1}" | sed "s@\([^:/]\)/\{1,\}@\1/@g"); if [ "x${2}" != "x" ]; then if [ "x${URL:1,-1}" != "x${2}" ]; then URL="${URL}${2}"; fi; fi; echo ${URL} } set_package_version () { echo -n "${2}" > ../package_version/${1}.version } set_proxy () { declare DOMAIN=$(echo ${1} | grep -o ".\{0,\}//[^/]\{0,\}" | awk -F'/' '{print $NF}'); declare PROXY_SERVER=$(cat proxy.set | grep -v "^#" | grep "${DOMAIN} " | awk -F' ' '{ print $2 }'); if [ "x${PROXY_SERVER}" == "x" ]; then unset https_proxy; else export https_proxy=${PROXY_SERVER}; fi } NULL
