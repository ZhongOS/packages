$1; NEW_VERSION=$2; if [ "x${OLD_VERSION}" == "x${NEW_VERSION}" ]; then echo 0; return; fi; TEST_VERSION=$(echo "${OLD_VERSION} ${NEW_VERSION}" | sort -V -r | head -n 1); if [ "x${TEST_VERSION}" == "x${NEW_VERSION}" ]; then echo 1; return; fi; echo 2 } get_current_version () { if [ -f ../package_version/${1}.version ]; then CURRENT_VERSION=$(cat ../package_version/${1}.version | sed 's/.*VERSION=\"\([^\"]\+\).*/\1/g'); echo ${CURRENT_VERSION}; return; fi; echo ""; return } get_ftp_new_file () { PKG_NAME=$(echo ${1} | sed "s@+@%2B@g"); TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); if [ "x${6}" == "x" ]; then wget --timeout=30 -q $(reformat_url ${2}) -O ${TMP_FILE}; else curl -A "${6}" $(reformat_url ${2}) -o ${TMP_FILE}; fi; declare $(bash common/ftp.method "${PKG_NAME}" "${TMP_FILE}" "${3}" "${4}" "${5}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_ftpdir_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q $(reformat_url ${2} '/') -O ${TMP_FILE}; declare $(bash common/ftpdir.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}" "${6}"); rm ${TMP_FILE}; echo "${DIR_NAME}" } get_github_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash -e common/github_dir.method "${TMP_FILE}" "${1}" "1" "${3}" "${4}"); rm ${TMP_FILE}; if [ "x${DIR_NAME}" == "x" ]; then echo "NULL"; exit; fi; TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${DIR_NAME}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash -e common/github.method "${1}" "${TMP_FILE}" "${3}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_github_new_file () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; if [ "x$?" != "x0"