format_url ${2}) -O ${TMP_FILE}; else curl -A "${6}" $(reformat_url ${2}) -o ${TMP_FILE}; fi; declare $(bash common/ftp.method "${PKG_NAME}" "${TMP_FILE}" "${3}" "${4}" "${5}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_ftpdir_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q $(reformat_url ${2} '/') -O ${TMP_FILE}; declare $(bash common/ftpdir.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}" "${6}"); rm ${TMP_FILE}; echo "${DIR_NAME}" } get_github_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash -e common/github_dir.method "${TMP_FILE}" "${1}" "1" "${3}" "${4}"); rm ${TMP_FILE}; if [ "x${DIR_NAME}" == "x" ]; then echo "NULL"; exit; fi; TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${DIR_NAME}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash -e common/github.method "${1}" "${TMP_FILE}" "${3}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_github_new_file () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash -e common/github.method "${1}" "${TMP_FILE}" "${3}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_github_new_webdir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash -e common/github_dir.method "${TMP_FILE}" "${1}" "1" "${4}" "${5}"); rm ${TMP_FILE}; TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${DIR_NAME}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash common/ftp.method "${1#*/}" "${TMP_FILE}" "${3}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_gitlab_new_file () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); for RETRY in {1..5}; do wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then if [ "x${RETRY}" == "x5" ]; then echo "NULL"; exit; else continue; fi; else break; fi; done; declare $(bash -e common/gitlab.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_package_name () { if [ "x${1}" == "x" ]; then echo ""; else echo "${1}" | awk -F'/' '{ print $NF }'; fi; return } get_package_url () { declare BASE_URL; declare HTML_SUFF; DAEMON=$(echo "$1" | grep -o "\(http\|https\|ftp\|ftps\)\:\/\/\(.[^/]*\)\/\{0,1\}"); HEAD_STR=$(echo "${2}" | awk -F'/' '{ print $1 }'); case "x${HEAD_STR}" in "x${2}") BASE_URL=${1}; HTML_SUFF=$(echo ${BASE_URL} | awk -F '/' '{ print $NF }' | awk -F '.' '{ print $NF }'); if [ "x${HTML_SUFF}" == "xhtml" ] || [ "x${HTML_SUFF}" == "xhtm" ] || [ "x${HTML_SUFF}" == "xphp" ]; then BASE_URL="${BASE_URL%/*}/"; fi; REL_URL=${BASE_URL}/${2} ;; "x") if [ "x${2:0:2}" == "x//" ]; then REL_URL="http:${2}"; else REL_URL="${DAEMON}/${2}"; fi ;; "xhttps:" | "xftp:" | "xhttp:" | "xftps:") REL_URL="${2}" ;; *) BASE_URL=${1}; HTML_SUFF=$(echo ${BASE_URL} | awk -F '/' '{ print $NF }' | awk -F '.' '{ print $NF }'); if [ "x${HTML_SUFF}" == "xhtml" ] || [ "x${HTML_SUFF}" == "xhtm" ] || [ "x${HTML_SUFF}" == "xphp" ]; then BASE_URL="${BASE_URL%/*}/"; fi; REL_URL="${BASE_URL}/${2}" ;; esac; reformat_url "${REL_URL}" } get_package_version () { declare RE_NAME=""; if [ "x${3}" != "x" ]; then RE_NAME="${3}"; else RE_NAME="${1}"; fi; RET_VAL_1=$(echo $2 | awk -F'/' '{print $NF}' | sed "s@^${RE_NAME}[-|_|\.]\{0,1\}@@g" | sed -e "s@\.tar\.[bz2|xz|gz]*\$@@g" -e "s@\.tgz\$@@g" -e "s@\.zip\$@@g" | sed -e "s@[-_\.]\{0,1\}\(source\|src\|stable\|orig\)@@g"); RET_VAL_2=$(echo "${RET_VAL_1}" | grep -v -e "[[:digit:]|-|_]latest" -e "[[:digit:]|-|_]rc[0-9]\{0,\}" -e "[[:digit:]|-|_]beta[0-9]\{0,\}" -e "[[:digit:]|-|_]alpha[0-9]\{0,\}" -e "[[:digit:]|-|_]preview[0-9]\{0,\}" ); RET_VAL=$(echo "${RET_VAL_2}" | uniq | sort -V -r | head -n 1); echo "${RET_VAL}" } get_sf_new_file () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q $(reformat_url ${2}) -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then echo "NULL"; exit; fi; declare $(bash common/sf.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}"); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_sfdir_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q $(reformat_url ${2}) -O ${TMP_FILE}; if [ "x$?" != "x0" ]; then echo "NULL"; exit; fi; declare $(bash -e common/sfdir.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}" "${6}" "${7}"); rm ${TMP_FILE}; echo "${DIR_NAME}" } get_webpage_new_file () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q ${2} -O ${TMP_FILE}; declare $(bash common/webpage.method ${1} ${TMP_FILE}); rm ${TMP_FILE}; echo "${FILE_NAME}" } get_webpagedir_new_dir () { TMP_FILE=$(mktemp -p ${TMP_DIRECTORY}); wget --timeout=30 -q ${2}/ -O ${TMP_FILE}; declare $(bash -e common/webpagedir.method "${1}" "${TMP_FILE}" "${3}" "${4}" "${5}"); rm ${TMP_FILE}; echo "${DIR_NAME}" } reformat_url () { declare URL; URL=$(echo "${1}" | sed "s@\([^:/]\)/\{1,\}@\1/@g"); if [ "x${2}" != "x" ]; then if [ "x${URL:1,-1}" != "x${2}" ]; then URL="${URL}${2}"; fi; fi; echo ${URL} } set_package_version () { echo -n "${2}" > ../package_version/${1}.version } set_proxy () { declare DOMAIN=$(echo ${1} | grep -o ".\{0,\}//[^/]\{0,\}" | awk -F'/' '{print $NF}'); declare PROXY_SERVER=$(cat proxy.set | grep -v "^#" | grep "${DOMAIN} " | awk -F' ' '{ print $2 }'); if [ "x${PROXY_SERVER}" == "x" ]; then unset https_proxy; else export https_proxy=${PROXY_SERVER}; fi } NULL
